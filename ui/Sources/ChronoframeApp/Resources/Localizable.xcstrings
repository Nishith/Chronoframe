    "Visual similarities are capped at medium confidence for review.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Visual similarities are capped at medium confidence for review."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las similitudes visuales se limitan a confianza media para su revisión."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les similitudes visuelles sont plafonnées à une confiance moyenne pour vérification."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Visuelle Ähnlichkeiten werden zur Überprüfung auf mittlere Vertrauenswürdigkeit begrenzt."
          }
        },
        "ja": {
          "stringUnit": {
