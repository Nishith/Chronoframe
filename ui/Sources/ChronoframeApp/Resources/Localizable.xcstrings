          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Semelhanças visuais são limitadas a média confiança para revisão."
          }
        }
      }
    },
    "Files are moved to Trash, never deleted immediately.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Files are moved to Trash, never deleted immediately."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los archivos se mueven a la Papelera, nunca se eliminan de inmediato."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les fichiers sont déplacés vers la corbeille, jamais supprimés immédiatement."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dateien werden in den Papierkorb verschoben, niemals sofort gelöscht."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ファイルはゴミ箱に移動され、即座に削除されることはありません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
