            "state": "translated",
            "value": "Organisation sécurisée et automatisée de photos et de vidéos."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sichere, automatisierte Foto- und Videoorganisation."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "安全で自動化された写真と動画の整理。"
          }
        },
        "zh-Hans": {
