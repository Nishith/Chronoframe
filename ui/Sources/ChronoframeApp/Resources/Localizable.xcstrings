    },
    "Originals are never modified or moved.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Originals are never modified or moved."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los originales nunca se modifican ni se mueven."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les originaux ne sont jamais modifiés ni déplacés."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Originale werden niemals geändert oder verschoben."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オリジナルファイルが変更または移動されることはありません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "原始文件永远不会被修改或移动。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Gli originali non vengono mai modificati o spostati."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Os originais nunca são modificados ou movidos."
          }
        }
      }
    },
    "Copies are validated before completion.": {
