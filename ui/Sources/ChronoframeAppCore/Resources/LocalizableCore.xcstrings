    "Chronoframe ran into a problem. Try again.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe ran into a problem. Try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe encontró un problema. Inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe a rencontré un problème. Veuillez réessayer."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe hat ein Problem festgestellt. Bitte versuchen Sie es erneut."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframeで問題が発生しました。もう一度お試しください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe 遇到了一个问题。请重试。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe ha riscontrato un problema. Riprova."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Chronoframe encontrou um problema. Tente novamente."
          }
        }
      }
    },
    "Chronoframe could not update Setup. Choose the folder again, or check that the drive is connected.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe could not update Setup. Choose the folder again, or check that the drive is connected."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe no pudo actualizar la configuración. Elige la carpeta de nuevo, o verifica que la unidad esté conectada."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe n'a pas pu mettre à jour la configuration. Choisissez à nouveau le dossier ou vérifiez que le lecteur est connecté."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe konnte das Setup nicht aktualisieren. Wählen Sie den Ordner erneut aus oder prüfen Sie, ob das Laufwerk angeschlossen ist."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframeは設定を更新できませんでした。フォルダーを再選択するか、ドライブが接続されていることを確認してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe 无法更新设置。请重新选择文件夹，或检查驱动器是否已连接。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe non ha potuto aggiornare la configurazione. Scegli nuovamente la cartella o verifica che l'unità sia connessa."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Chronoframe não pôde atualizar a Configuração. Escolha a pasta novamente ou verifique se o disco está conectado."
          }
        }
      }
    },
    "Chronoframe could not use the dropped items. Try choosing the source folder with the picker instead.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe could not use the dropped items. Try choosing the source folder with the picker instead."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe no pudo usar los elementos soltados. Intenta elegir la carpeta de origen con el selector en su lugar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe n'a pas pu utiliser les éléments déposés. Essayez plutôt de choisir le dossier source avec le sélecteur."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe konnte die abgelegten Elemente nicht verwenden. Versuchen Sie stattdessen, den Quellordner über die Auswahl zu wählen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframeはドロップされたアイテムを使用できませんでした。代わりに選択ツールのダイアログでソースフォルダーを選択してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe 无法使用拖入的项目。请尝试使用选择器选择源文件夹。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe non ha potuto utilizzare gli elementi rilasciati. Prova a scegliere la cartella sorgente con il selettore."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Chronoframe não pôde usar os itens soltos. Tente escolher a pasta de origem com o seletor."
          }
        }
      }
    },
    "Chronoframe could not update saved profiles. Check that Chronoframe can write to its settings, then try again.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe could not update saved profiles. Check that Chronoframe can write to its settings, then try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe no pudo actualizar los perfiles guardados. Verifica que Chronoframe pueda escribir en su configuración, luego inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe n'a pas pu mettre à jour les profils enregistrés. Vérifiez que Chronoframe peut écrire dans ses paramètres, puis réessayez."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe konnte die gespeicherten Profile nicht aktualisieren. Prüfen Sie, ob Chronoframe in die Einstellungen schreiben kann, und versuchen Sie es erneut."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframeは保存されたプロファイルを更新できませんでした。Chronoframeが設定を書き込める状態か確認してから、やり直してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe 无法更新保存的配置文件。请检查 Chronoframe 是否能够写入其设置，然后重试。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe non ha potuto aggiornare i profili salvati. Verifica que Chronoframe possa scrivere nelle sue impostazioni, quindi riprova."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Chronoframe não pôde atualizar os perfis salvos. Verifique se o Chronoframe tem permissão para gravar nas suas configurações e tente novamente."
          }
        }
      }
    },
    "Chronoframe could not finish this run. Your source files were left untouched. Check that both folders are available, then try again.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe could not finish this run. Your source files were left untouched. Check that both folders are available, then try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe no pudo finalizar esta ejecución. Tus archivos de origen no fueron modificados. Verifica que ambas carpetas estén disponibles, luego inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe n'a pas pu terminer cette exécution. Vos fichiers sources n'ont pas été touchés. Vérifiez que les deux dossiers sont disponibles, puis réessayez."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe konnte diesen Durchlauf nicht beenden. Ihre Quelldateien wurden nicht verändert. Prüfen Sie, ob beide Ordner verfügbar sind, und versuchen Sie es erneut."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframeはこの処理を完了できませんでした。元のソースファイルは変更されていません。両方のフォルダーが利用可能であることを確認し、もう一度お試しください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe 无法完成此次运行。您的源文件未被修改。请检查这两个文件夹是否可用，然后重试。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe non ha potuto completare questa esecuzione. I file sorgente non sono stati modificati. Verifica che entrambe le cartelle siano disponibili, quindi riprova."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Chronoframe não pôde concluir esta execução. Seus arquivos de origem não foram modificados. Verifique se ambas as pastas estão disponíveis e tente novamente."
          }
        }
      }
    },
    "Chronoframe could not refresh Run History. Check that the destination drive is connected, then try again.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe could not refresh Run History. Check that the destination drive is connected, then try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe no pudo actualizar el Historial de ejecuciones. Verifica que la unidad de destino esté conectada, luego inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe n'a pas pu actualiser l'historique des exécutions. Vérifiez que le lecteur de destination est connecté, puis réessayez."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe konnte den Verlauf nicht aktualisieren. Prüfen Sie, ob das Ziellaufwerk angeschlossen ist, und versuchen Sie es erneut."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframeは実行履歴を更新できませんでした。同期先のドライブが接続されていることを確認し、もう一度お試しください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe 无法刷新运行历史记录。请检查目标驱动器是否已连接，然后重试。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe non ha potuto aggiornare la cronologia delle esecuzioni. Verifica che l'unità di destinazione sia connessa, quindi riprova."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Chronoframe não pôde atualizar o Histórico de Execuções. Verifique se o disco de destino está conectado e tente novamente."
          }
        }
      }
    },
    "Chronoframe could not read one of its saved files because the file format looked different than expected. Run a new preview or transfer to create a fresh file.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe could not read one of its saved files because the file format looked different than expected. Run a new preview or transfer to create a fresh file."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe no pudo leer uno de sus archivos guardados porque el formato del archivo parecía diferente de lo esperado. Ejecuta una nueva vista previa o transferencia para crear un archivo nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe n'a pas pu lire l'un de ses fichiers enregistrés car le format du fichier semblait différent de celui attendu. Lancez un nouvel aperçu ou un transfert pour créer un fichier propre."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe konnte eine seiner gespeicherten Dateien nicht lesen, da das Dateiformat nicht den Erwartungen entsprach. Starten Sie eine neue Vorschau oder einen Transfer, um eine neue Datei zu erstellen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "保存されたファイルの一つが予想と異なるフォーマットであるため、Chronoframeは読み込めませんでした。新規にプレビューまたは転送を行って新しいファイルを作成してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe 无法读取其保存的文件，因为文件格式与预期不同。请运行新的预览或传输以创建新文件。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe non ha potuto leggere uno dei suoi file salvati perché il formato del file sembrava diverso da quello previsto. Esegui una nuova anteprima o trasferimento per creare un file pulito."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Chronoframe não pôde ler um dos seus arquivos salvos porque o formato do arquivo parecia diferente do esperado. Execute uma nova pré-visualização ou transferência para criar um arquivo limpo."
          }
        }
      }
    },
    "Chronoframe needs one more choice before it can continue. Review Setup, then try again.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe needs one more choice before it can continue. Review Setup, then try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe necesita una decisión más antes de poder continuar. Revisa la configuración, luego inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe a besoin d'un choix supplémentaire avant de pouvoir continuer. Vérifiez la configuration, puis réessayez."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
