          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe no pudo verificar si este archivo cambió, por lo que fue dejado en su lugar. Archivo: %@."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe n'a pas pu vérifier si ce fichier a été modifié. Il a donc été laissé sur place. Fichier : %@."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe konnte nicht überprüfen, ob sich diese Datei geändert hat, sodass sie unverändert gelassen wurde. Datei: %@."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframeはこのファイルが変更されたかどうか確認できなかったため、そのまま残されました。ファイル: %@。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe 无法检查此文件是否已更改，因此已将其保留在原处。文件：%@。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe non ha potuto verificare se questo file sia cambiato, quindi lo ha lasciato intatto. File: %@."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Chronoframe não pôde verificar se este arquivo foi alterado, portanto, ele foi deixado no lugar. Arquivo: %@."
          }
        }
      }
    },
    "Chronoframe kept this file because it has changed since the original transfer. File: %@.": {
