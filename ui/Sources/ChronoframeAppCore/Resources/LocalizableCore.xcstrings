    "Chronoframe copied this file but could not verify the copy, so the destination copy was removed and the source was left untouched. Source: %@. Destination: %@.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe copied this file but could not verify the copy, so the destination copy was removed and the source was left untouched. Source: %@. Destination: %@."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe copió este archivo pero no pudo verificar la copia, por lo que la copia de destino fue eliminada y el origen no fue modificado. Origen: %@. Destino: %@."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe a copié ce fichier mais n'a pas pu vérifier la copie. La copie de destination a donc été supprimée et la source n'a pas été modifiée. Source : %@. Destination : %@."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe hat diese Datei kopiert, konnte die Kopie jedoch nicht verifizieren, sodass die Zielkopie entfernt und die Quelle unverändert gelassen wurde. Quelle: %@. Ziel: %@."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframeはこのファイルをコピーしましたが、コピーを検証できなかったため、コピー先が削除され、元ファイルは変更されませんでした。コピー元: %@。コピー先: %@。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe 复制了此文件但无法验证副本，因此目标副本已删除，源文件保持不变。源：%@。目标：%@。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe ha copiato questo file ma non ha potuto verificare la copia, quindi la copia di destinazione è stata rimossa e la sorgente è stata lasciata intatta. Sorgente: %@. Destinazione: %@."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Chronoframe copiou este arquivo, mas não pôde verificar a cópia, portanto, a cópia de destino foi removida e a origem não foi modificada. Origem: %@. Destino: %@."
          }
        }
      }
    },
