    "A file or folder Chronoframe needs is no longer available. Reconnect the drive or choose the folder again, then try again.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A file or folder Chronoframe needs is no longer available. Reconnect the drive or choose the folder again, then try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un archivo o carpeta que Chronoframe necesita ya no está disponible. Reconecta la unidad o elige la carpeta de nuevo, luego inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un fichier ou dossier nécessaire à Chronoframe n'est plus disponible. Rebranchez le lecteur ou choisissez à nouveau le dossier, puis réessayez."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Eine Datei oder ein Ordner, den Chronoframe benötigt, ist nicht mehr verfügbar. Verbinden Sie das Laufwerk erneut oder wählen Sie den Ordner erneut aus, und versuchen Sie es dann noch einmal."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframeが必要とするファイルまたはフォルダーが利用できなくなりました。ドライブを再接続するかフォルダーを再選択し、もう一度お試しください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe 所需的文件或文件夹已不可用。请重新连接驱动器或重新选择文件夹，然后重试。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Un file o una cartella di cui Chronoframe ha bisogno non è più disponibile. Riconnetti l'unità o scegli nuovamente la cartella, quindi riprova."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Um arquivo ou pasta de que o Chronoframe precisa não está mais disponível. Reconecte o disco ou escolha a pasta novamente e tente novamente."
          }
        }
      }
    },
    "macOS is blocking access to a file or folder. Choose the folder again to grant access, or check Privacy & Security settings.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS is blocking access to a file or folder. Choose the folder again to grant access, or check Privacy & Security settings."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS está bloqueando el acceso a un archivo o carpeta. Elige la carpeta de nuevo para otorgar acceso, o verifica la configuración de Privacidad y seguridad."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS bloque l'accès à un fichier ou un dossier. Choisissez à nouveau le dossier pour accorder l'accès ou vérifiez les paramètres de confidentialité et de sécurité."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS blockiert den Zugriff auf eine Datei oder einen Ordner. Wählen Sie den Ordner erneut aus, um den Zugriff zu gestatten, oder überprüfen Sie die Datenschutz- und Sicherheitseinstellungen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "macOSによってファイルまたはフォルダーへのアクセスがブロックされています。アクセスを許可するためにフォルダーを再選択するか、「プライバシーとセキュリティ」設定を確認してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS 正在阻止对文件或文件夹的访问。请重新选择文件夹以授予访问权限，或检查“隐私与安全”设置。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS sta bloccando l'accesso a un file o a una cartella. Scegli nuovamente la cartella per concedere l'accesso o verifica le impostazioni di Privacy e Sicurezza."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O macOS está bloqueando o acesso a um arquivo ou pasta. Escolha a pasta novamente para conceder acesso ou verifique as configurações de Privacidade e Segurança."
          }
        }
      }
    },
    "The destination drive is out of space. Free up space or choose a different destination, then try again.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The destination drive is out of space. Free up space or choose a different destination, then try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La unidad de destino no tiene espacio. Libera espacio o elige un destino diferente, luego inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le lecteur de destination est saturé. Libérez de l'espace ou choisissez une autre destination, puis réessayez."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Ziellaufwerk ist voll. Geben Sie Speicherplatz frei oder wählen Sie ein anderes Ziel und versuchen Sie es erneut."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "同期先のドライブの空き容量が不足しています。空き容量を増やすか別の同期先を選択し、もう一度お試しください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "目标驱动器空间不足。请释放空间或选择其他目标，然后重试。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'unità di destinazione ha esaurito lo spazio. Libera spazio o scegli una destinazione diversa, quindi riprova."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O disco de destino está sem espaço. Libere espaço ou escolha um destino diferente e tente novamente."
          }
        }
      }
    },
    "The destination is read-only. Choose a writable folder or change the drive permissions, then try again.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The destination is read-only. Choose a writable folder or change the drive permissions, then try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El destino es de solo lectura. Elige una carpeta con permisos de escritura o cambia los permisos de la unidad, luego inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le dossier de destination est en lecture seule. Choisissez un dossier accessible en écriture ou modifiez les autorisations du lecteur, puis réessayez."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Ziel ist schreibgeschützt. Wählen Sie einen beschreibbaren Ordner oder ändern Sie die Laufwerksberechtigungen und versuchen Sie es erneut."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "同期先は読み取り専用です。書き込み可能なフォルダーを選択するかドライブのアクセス権を変更し、もう一度お試しください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "目标是只读的。请选择可写文件夹或更改驱动器权限，然后重试。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La destinazione è di sola lettura. Scegli una cartella scrivibile o modifica i permessi dell'unità, quindi riprova."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O destino é somente leitura. Escolha uma pasta gravável ou altere as permissões do disco e tente novamente."
          }
        }
      }
    },
    "Chronoframe could not read a saved file because it appears to be damaged. Run a new preview or transfer to create a fresh file.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe could not read a saved file because it appears to be damaged. Run a new preview or transfer to create a fresh file."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe no pudo leer un archivo guardado porque parece estar dañado. Ejecuta una nueva vista previa o transferencia para crear un archivo nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe n'a pas pu lire un fichier enregistré car il semble endommagé. Lancez un nouvel aperçu ou un transfert pour créer un fichier propre."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe konnte eine gespeicherte Datei nicht lesen, da sie beschädigt zu sein scheint. Starten Sie eine neue Vorschau oder einen Transfer, um eine neue Datei zu erstellen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ファイルが破損している可能性があるため、Chronoframeは保存されたファイルを読み込めませんでした。新規にプレビューまたは転送を行って新しいファイルを作成してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe 无法读取已保存的文件，因为它似乎已损坏。请运行新的预览或传输以创建新文件。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Chronoframe non ha potuto leggere un file salvato perché sembra essere danneggiato. Esegui una nuova anteprima o trasferimento per creare un file pulito."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Chronoframe não pôde ler um arquivo salvo porque ele parece estar corrompido. Execute uma nova pré-visualização ou transferência para criar um arquivo limpo."
          }
        }
      }
    },
